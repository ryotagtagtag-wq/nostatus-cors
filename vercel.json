{
  "rewrites": [
    {
      "source": "/api/nrelay/:path*",
      "destination": "https://nrelay-proxy.ryotagtagtag.workers.dev/api/nrelay/:path*"
    },
    {
      "source": "/api/songdata/:path*",
      "destination": "https://nrelay-proxy.ryotagtagtag.workers.dev/api/songdata/:path*"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
